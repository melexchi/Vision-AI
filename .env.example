# Vision-AI Environment Variables
# Copy to .env and fill in values. All have sensible defaults.

# ─── Ditto Service (Port 8181) ───
DITTO_PATH=./ditto-talkinghead          # Path to Ditto inference engine
DITTO_BACKEND=onnx                      # Inference backend: "trt" (TensorRT) or "onnx" (ONNX Runtime)
AVATAR_CACHE_DIR=/workspace/avatar_cache  # Avatar feature pickle cache directory
AVATAR_CLIPS_DIR=/workspace/avatar_clips  # Pre-rendered expression clip directory
AVATAR_IMAGES_DIR=/workspace/avatar_images # Avatar source image directory
CLIP_CACHE_MAX=20                        # Max decoded clips in memory (LRU eviction)

# ─── Inter-Service ───
TTS_URL=http://localhost:8080/tts/stream  # Chatterbox TTS endpoint URL

# ─── SkyReels Integration ───
SKYREELS_PATH=/workspace/SkyReels-A1     # Path to SkyReels-A1 installation
SKYREELS_PYTHON=.venv/bin/python          # Python interpreter in SkyReels venv
# PRERENDER_SCRIPT=                       # Override path to prerender_clips.py (auto-derived)

# ─── SmolVLM Service (Port 8282) ───
SMOLVLM_MODEL=HuggingFaceTB/SmolVLM2-2.2B-Instruct  # HuggingFace model ID
SMOLVLM_DEVICE=cuda:0                    # GPU device (cuda:0, cuda:1, cpu)
SMOLVLM_PORT=8282                         # Server port

# ─── Build / System ───
# HF_TOKEN=                              # HuggingFace token for private model downloads
# HF_HUB_ENABLE_HF_TRANSFER=1           # Enable parallel HuggingFace downloads
# LD_LIBRARY_PATH=                       # TensorRT library paths (set by setup.sh)
# CUDA_HOME=                             # CUDA toolkit path (for pytorch3d build)
